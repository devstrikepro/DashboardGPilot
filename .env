# Gateway Proxy — ชี้ไปที่ Backend จริง (ใช้โดย next.config.mjs rewrites)
API_URL=http://localhost:8000

# API Key — ส่งเป็น X-API-Key header ไปกับทุก request (ต้องตรงกับ API_KEY ใน Backend/.env)
NEXT_PUBLIC_API_KEY=Tarzan

# Mock Mode — false = ยิง API จริง, true = ใช้ข้อมูลจำลอง
NEXT_PUBLIC_IS_MOCK_MODE=false